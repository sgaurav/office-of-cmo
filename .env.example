# Office of CMO — Environment variables
# Copy to .env and fill in. Most are optional; skills degrade gracefully without them.

# --- Ad platform API access (used by /ads-performance-review, /ads-platform-setup) ---
# Skills will check for these and fall back to "paste a CSV" mode if missing.
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

META_ADS_ACCESS_TOKEN=
META_ADS_AD_ACCOUNT_ID=

LINKEDIN_ADS_ACCESS_TOKEN=
LINKEDIN_ADS_ACCOUNT_ID=

TIKTOK_ADS_ACCESS_TOKEN=
TIKTOK_ADS_ADVERTISER_ID=

# --- Analytics ---
GA4_PROPERTY_ID=
GA4_SERVICE_ACCOUNT_PATH=

# --- Research / enrichment (optional) ---
APOLLO_API_KEY=
SEMRUSH_API_KEY=
SIMILARWEB_API_KEY=

# --- Office of CMO config ---
# Where to write artifacts. Defaults to ./artifacts in the project root.
OCMO_ARTIFACTS_DIR=
# Where cmo-memory lives. Defaults to ~/.claude/skills/office-of-cmo/cmo-memory/state
OCMO_MEMORY_DIR=
